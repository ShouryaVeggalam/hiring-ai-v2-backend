# ============================================================
# CELESTRA HIRING AI - Environment Configuration
# ============================================================

# ---- Application ----
APP_NAME="Celestra Hiring AI"
APP_ENV=development            # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-super-secret-key-please-rotate-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
# Comma-separated list of allowed origins, or "*" for any.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Database ----
POSTGRES_USER=celestra
POSTGRES_PASSWORD=celestra
POSTGRES_DB=celestra_hiring
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Optionally override the full URL (managed hosts like Render set this for you;
# postgres:// and postgresql:// URLs are auto-normalized to psycopg2):
# DATABASE_URL=postgresql+psycopg2://celestra:celestra@localhost:5432/celestra_hiring

# Create tables automatically on startup (useful for free PaaS without a
# separate migration step). Set to false to rely solely on Alembic.
AUTO_CREATE_TABLES=true

# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- AI / LLM ----
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
# Set to true to run agents without calling a real model (deterministic stubs)
LLM_OFFLINE_MODE=true

# ---- First superuser (auto-seeded on startup) ----
FIRST_SUPERUSER_EMAIL=admin@celestra.ai
FIRST_SUPERUSER_PASSWORD=Admin@12345
FIRST_SUPERUSER_NAME=Celestra Admin
